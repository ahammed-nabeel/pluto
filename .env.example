# ============================
# Proteus — Environment Variables
# Copy this to .env.local and fill in your values
# ============================

# ── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/proteus_db"

# ── Auth.js / NextAuth ────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Microsoft OAuth (https://portal.azure.com)
AUTH_MICROSOFT_ENTRA_ID_ID="your-microsoft-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-microsoft-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/common/v2.0"

# ── File Storage ──────────────────────────────────────
# Leave empty to use local filesystem in development
# Set all three to activate AWS S3 in production
STORAGE_PROVIDER="local"  # "local" | "s3"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
S3_BUCKET_NAME=""
S3_ENDPOINT=""  # For S3-compatible providers (e.g., MinIO, Cloudflare R2)

# ── Maps ──────────────────────────────────────────────
# Optional: provide Google Maps API key to use Google Maps instead of Leaflet
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Proteus"

# ── Cron Secret (protect cron endpoint) ──────────────
CRON_SECRET="your-cron-secret-here"

# ── Email / SMTP ──────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@pluto.com"
