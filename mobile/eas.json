{
  "cli": {
    "version": ">= 8.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://pluto-v2.vercel.app/api",
        "EXPO_PUBLIC_APP_NAME": "Proteus"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://pluto-v2.vercel.app/api",
        "EXPO_PUBLIC_APP_NAME": "Proteus"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
