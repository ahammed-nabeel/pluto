{
  "expo": {
    "name": "Pluto",
    "slug": "pluto",
    "scheme": "pluto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#203A70",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.brandcaster.pluto",
      "predictiveBackGestureEnabled": false
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#203A70"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "./withAppName.js",
        "Pluto."
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59da9270-3265-40dd-bd91-278f83c03c48"
      }
    },
    "owner": "ahammednabeels-team"
  }
}
